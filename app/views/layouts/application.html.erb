<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="dark">
  <head>
    <title><%= content_for(:title) || "Meridian" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0A0908">
    <meta name="turbo-prefetch" content="true">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Google Fonts: Fraunces (display) + DM Sans (body) %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..900,0..100&family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# Chart.js + Chartkick (UMD scripts — kept out of importmap to avoid ESM module-scope ReferenceError that broke Stimulus).
        chartjs-adapter-date-fns is required by Chart.js v4 for any time-based axis — Chartkick auto-detects date-like keys, so even
        string-formatted dates trigger it. Loading the adapter once globally lets every chart work without per-call options. %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" data-turbo-track="reload"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js" data-turbo-track="reload"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0" data-turbo-track="reload"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick@5.0.1/dist/chartkick.min.js" data-turbo-track="reload"></script>
    <%# Apache ECharts — used by the finance dashboard chart card for richer motion / pie animations.
        Chartkick + Chart.js are still loaded for the simpler charts elsewhere. %>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js" data-turbo-track="reload"></script>
  </head>

  <body class="min-h-screen bg-[var(--color-bg-base)] text-[var(--color-fg-primary)] font-[family-name:var(--font-sans)]" data-controller="theme keyboard-nav">
    <div class="flex min-h-screen">
      <%= render ::Layouts::Sidebar.new(active: content_for(:nav_key)&.to_sym) %>

      <div class="flex-1 flex flex-col min-w-0">
        <%= render ::Layouts::TopBar.new(title: content_for(:page_title), user: current_user) %>

        <main class="flex-1 px-4 md:px-8 py-6 pb-24 md:pb-6 max-w-[var(--container-page)] w-full mx-auto">
          <%= render "shared/flash" %>
          <%= yield %>
        </main>
      </div>

      <%= render ::Layouts::BottomNav.new(active: content_for(:nav_key)&.to_sym) %>

      <%# Quick capture is still available via the "c" keyboard shortcut. %>
      <% if user_signed_in? %>
        <div data-controller="quick-capture"
             data-quick-capture-placeholder-value="<%= t('quick_capture.placeholder') %>"
             data-quick-capture-hint-value="<%= t('quick_capture.hint') %>"
             data-quick-capture-button-value="<%= t('quick_capture.button') %>"
             class="hidden"></div>
      <% end %>

      <%# Global Turbo Frame modal — populated by links with data-turbo-frame="modal" %>
      <div data-controller="modal" class="hidden">
        <div data-modal-target="centerer">
          <turbo-frame id="modal"></turbo-frame>
        </div>
      </div>
    </div>
  </body>
</html>
