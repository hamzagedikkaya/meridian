<% content_for :page_title, t("nav.dashboard") %>
<% content_for :nav_key, "dashboard" %>

<%
  greeting = case Time.current.hour
             when 0..11  then t("pages.home.greeting_morning")
             when 12..17 then t("pages.home.greeting_afternoon")
             else             t("pages.home.greeting_evening")
             end
%>

<div class="space-y-6">
  <div>
    <h2 class="font-[family-name:var(--font-display)] text-4xl tracking-tight">
      <%= greeting %>, <%= current_user.display_name %>.
    </h2>
    <p class="text-[var(--color-fg-muted)] mt-1"><%= l(Date.current, format: "%A, %d %B %Y") %></p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <div class="card">
      <p class="text-xs text-[var(--color-fg-muted)] uppercase tracking-wider"><%= t("pages.home.net_this_month") %></p>
      <p class="stat-number mt-2 !text-2xl <%= @month_net_cents >= 0 ? 'text-[var(--color-income)]' : 'text-[var(--color-expense)]' %>"><%= money_format(@month_net_cents, currency: @currency) %></p>
    </div>
    <div class="card">
      <p class="text-xs text-[var(--color-fg-muted)] uppercase tracking-wider"><%= t("pages.home.active_streaks") %></p>
      <p class="stat-number mt-2 !text-2xl flex items-center gap-2">
        <span class="text-[var(--color-warning)]"><%= render Ui::Icon.new(name: "flame", size: 22) %></span>
        <%= @active_streaks %>
      </p>
    </div>
    <div class="card">
      <p class="text-xs text-[var(--color-fg-muted)] uppercase tracking-wider"><%= t("pages.home.open_todos") %></p>
      <p class="stat-number mt-2 !text-2xl"><%= @open_todos %></p>
    </div>
    <div class="card">
      <p class="text-xs text-[var(--color-fg-muted)] uppercase tracking-wider"><%= t("pages.home.todays_events") %></p>
      <p class="stat-number mt-2 !text-2xl"><%= @today_events %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="card lg:row-span-2">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-[family-name:var(--font-display)] text-xl tracking-tight"><%= t("pages.home.habits_today") %></h3>
        <%= link_to t("common.all") + " →", habits_path, class: "text-xs text-[var(--color-accent-400)]" %>
      </div>
      <% if @today_habits.any? %>
        <ul class="space-y-3.5">
          <% @today_habits.each do |habit| %>
            <%= render "pages/dashboard_habit", habit: habit %>
          <% end %>
        </ul>
        <div class="mt-4 pt-3 border-t border-[var(--color-border-subtle)] text-xs text-[var(--color-fg-muted)]">
          <%= t("pages.home.weekly_completion") %>: <strong class="text-[var(--color-fg-primary)]"><%= @habit_completion_pct %>%</strong>
        </div>
      <% else %>
        <p class="text-sm text-[var(--color-fg-muted)]"><%= t("pages.home.no_habits") %> <%= link_to t("pages.home.add_one"), new_habit_path, class: "text-[var(--color-accent-400)]" %>.</p>
      <% end %>
    </div>

    <div class="card">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-[family-name:var(--font-display)] text-xl tracking-tight"><%= t("pages.home.upcoming_todos") %></h3>
        <%= link_to t("common.all") + " →", todos_path, class: "text-xs text-[var(--color-accent-400)]" %>
      </div>
      <% if @upcoming_todos.any? %>
        <ul class="space-y-2">
          <% @upcoming_todos.each do |t| %>
            <li class="flex items-center gap-2 text-sm">
              <%= link_to t.title, edit_todo_path(t), class: "truncate hover:text-[var(--color-accent-400)]" %>
              <% if t.due_at %>
                <span class="ml-auto text-xs <%= t.overdue? ? 'text-[var(--color-expense)]' : 'text-[var(--color-fg-faint)]' %>"><%= l(t.due_at.to_date, format: "%d %b") %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-[var(--color-fg-muted)]"><%= t("pages.home.all_clear") %></p>
      <% end %>
    </div>

    <div class="card">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-[family-name:var(--font-display)] text-xl tracking-tight"><%= t("pages.home.today") %></h3>
        <%= link_to t("nav.calendar") + " →", calendar_path, class: "text-xs text-[var(--color-accent-400)]" %>
      </div>
      <% if @today_events_list.any? %>
        <ul class="space-y-2">
          <% @today_events_list.each do |e| %>
            <li class="flex items-center gap-2 text-sm">
              <span class="w-2 h-2 rounded-full" style="background: <%= e.color %>"></span>
              <span class="truncate"><%= e.title %></span>
              <span class="ml-auto text-xs text-[var(--color-fg-faint)]"><%= e.start_at.strftime("%H:%M") %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-[var(--color-fg-muted)]"><%= t("pages.home.no_events_today") %></p>
      <% end %>
    </div>

    <div class="card">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-[family-name:var(--font-display)] text-xl tracking-tight"><%= t("pages.home.last_7d_spend") %></h3>
        <%= link_to t("nav.finance") + " →", finance_root_path, class: "text-xs text-[var(--color-accent-400)]" %>
      </div>
      <% if @spending_series.any? %>
        <%= line_chart @spending_series.transform_values { |v| v / 100.0 }, colors: [ "#B85450" ], height: "140px", library: { plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } } %>
      <% else %>
        <p class="text-sm text-[var(--color-fg-muted)]"><%= t("pages.home.no_spending") %></p>
      <% end %>
    </div>

    <div class="card">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-[family-name:var(--font-display)] text-xl tracking-tight"><%= t("pages.home.goals") %></h3>
        <%= link_to t("common.all") + " →", goals_path, class: "text-xs text-[var(--color-accent-400)]" %>
      </div>
      <% if @active_goals.any? %>
        <ul class="space-y-3">
          <% @active_goals.each do |g| %>
            <li>
              <%= link_to g.name, goal_path(g), class: "text-sm hover:text-[var(--color-accent-400)]" %>
              <div class="mt-1.5 h-1.5 bg-[var(--color-bg-base)] rounded-full overflow-hidden">
                <div class="h-full" style="width: <%= g.progress_percent %>%; background: <%= g.color %>;"></div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-[var(--color-fg-muted)]"><%= link_to t("pages.home.set_goal"), new_goal_path, class: "text-[var(--color-accent-400)]" %></p>
      <% end %>
    </div>

  </div>
</div>
