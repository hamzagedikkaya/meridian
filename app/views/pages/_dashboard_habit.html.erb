<%# Single habit row used inside the dashboard "Habits today" widget.
    The <li> is the direct child of the parent <ul> so space-y-* on the
    list spaces these rows correctly. The turbo-frame inside isolates the
    swap target — toggling the checkbox redirects back to the dashboard,
    Turbo extracts this frame and replaces it in place. %>
<li>
  <turbo-frame id="<%= dom_id(habit, :dashboard) %>">
    <% done = habit.completed_on?(Date.current) %>
    <div class="flex items-center gap-3"
         data-controller="streak-celebration"
         data-streak-celebration-habit-id-value="<%= habit.id %>"
         data-streak-celebration-streak-value="<%= habit.current_streak %>">
      <%= render "habits/checkbox_toggle", habit: habit, size: :sm %>
      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-sm <%= 'text-[var(--color-fg-muted)] line-through' if done %>"><%= habit.name %></span>
          <% if habit.target_count > 1 %>
            <%= render "habits/habit_counter", habit: habit %>
          <% end %>
        </div>
        <div class="mt-1.5">
          <%= render Ui::HabitChain.new(links: habit.chain_window(days: 7), size: :sm, aria_label: t("habits.chain.aria", name: habit.name)) %>
        </div>
      </div>
      <span class="ml-auto text-xs text-[var(--color-fg-faint)] flex-shrink-0"><%= habit.current_streak %><%= t("habits.day_short") %></span>
    </div>
  </turbo-frame>
</li>
