<% content_for :page_title, "Habits" %>
<% content_for :nav_key, "habits" %>

<div class="space-y-6">
  <div class="flex items-end justify-between">
    <div>
      <h2 class="font-[family-name:var(--font-display)] text-4xl tracking-tight">Habits</h2>
      <p class="text-[var(--color-fg-muted)] mt-1"><%= Date.current.strftime("%A, %d %B") %></p>
    </div>
    <%= link_to "+ New habit", new_habit_path, class: "px-3 py-2 text-sm bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] rounded-[var(--radius-sm)] font-medium" %>
  </div>

  <% if @habits.any? %>
    <% completed_today = @habits.count { |h| h.completed_on?(Date.current) } %>
    <div class="card">
      <p class="text-sm text-[var(--color-fg-muted)]">Today</p>
      <p class="stat-number mt-2"><%= completed_today %>/<%= @habits.count %></p>
      <div class="mt-3 h-2 bg-[var(--color-bg-base)] rounded-full overflow-hidden">
        <div class="h-full bg-[var(--color-accent-500)] transition-all" style="width: <%= @habits.any? ? (completed_today.to_f / @habits.count * 100) : 0 %>%"></div>
      </div>
    </div>

    <div class="card !p-0">
      <ul class="divide-y divide-[var(--color-border-subtle)]">
        <% @habits.each do |habit| %>
          <% done = habit.completed_on?(Date.current) %>
          <li class="p-4 flex items-center gap-4">
            <%= button_to toggle_today_habit_path(habit), method: :patch, form: { class: "flex-shrink-0" }, class: "w-7 h-7 rounded-full border-2 #{done ? 'bg-[var(--color-accent-500)] border-[var(--color-accent-500)] text-[var(--color-bg-base)]' : 'border-[var(--color-border-default)] hover:border-[var(--color-accent-500)]'} flex items-center justify-center cursor-pointer transition-colors" do %>
              <% if done %><span class="text-sm leading-none">✓</span><% end %>
            <% end %>

            <div class="flex-1 min-w-0">
              <%= link_to habit.name, habit_path(habit), class: "text-base font-medium hover:text-[var(--color-accent-400)]" %>
              <p class="text-xs text-[var(--color-fg-muted)] mt-0.5">
                <%= habit.frequency.titleize %>
                <% if habit.description.present? %> · <%= habit.description %><% end %>
              </p>
            </div>

            <div class="text-right flex-shrink-0">
              <p class="text-sm font-medium">🔥 <%= habit.current_streak %></p>
              <p class="text-xs text-[var(--color-fg-muted)]"><%= habit.completion_rate(days: 30) %>% / 30d</p>
            </div>

            <div class="flex flex-col gap-1 text-xs ml-3">
              <%= link_to "Edit", edit_habit_path(habit), class: "text-[var(--color-accent-400)]" %>
              <%= button_to "Del", habit_path(habit), method: :delete, data: { turbo_confirm: "Delete habit and all logs?" }, class: "text-[var(--color-expense)] cursor-pointer" %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <div class="card text-center py-12">
      <p class="text-[var(--color-fg-muted)] mb-3">No habits yet.</p>
      <%= link_to "Create your first habit", new_habit_path, class: "text-[var(--color-accent-400)]" %>
    </div>
  <% end %>
</div>
