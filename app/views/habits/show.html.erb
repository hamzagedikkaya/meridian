<% content_for :page_title, @habit.name %>
<% content_for :nav_key, "habits" %>

<turbo-frame id="modal">
  <div class="w-full max-w-3xl bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-md)] shadow-2xl">
    <div class="px-5 py-4 border-b border-[var(--color-border-subtle)] flex items-center justify-between">
      <div class="flex items-center gap-3 min-w-0">
        <span class="w-3.5 h-3.5 rounded-full flex-shrink-0" style="background: <%= @habit.color %>"></span>
        <div class="min-w-0">
          <p class="text-xs text-[var(--color-fg-muted)] uppercase tracking-wider"><%= t("enums.frequency.#{@habit.frequency}") %></p>
          <h2 class="font-[family-name:var(--font-display)] text-2xl tracking-tight truncate"><%= @habit.name %></h2>
        </div>
      </div>
      <a href="#" data-action="click->modal#close" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)] flex-shrink-0">
        <%= render Ui::Icon.new(name: "x", size: 18) %>
      </a>
    </div>

    <div class="p-5 space-y-5">
      <% if @habit.description.present? %>
        <p class="text-sm text-[var(--color-fg-muted)]"><%= @habit.description %></p>
      <% end %>

      <%# 30-day chain %>
      <div>
        <div class="flex items-center justify-between mb-3">
          <h3 class="font-[family-name:var(--font-display)] text-lg tracking-tight"><%= t("habits.chain.title") %></h3>
          <p class="text-xs text-[var(--color-fg-muted)]"><%= t("habits.chain.window_30") %></p>
        </div>
        <%= render Ui::HabitChain.new(links: @habit.chain_window(days: 30), size: :lg, aria_label: t("habits.chain.aria", name: @habit.name)) %>
        <div class="flex items-center gap-4 text-xs text-[var(--color-fg-muted)] mt-3">
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full" style="background: <%= @habit.color %>"></span><%= t("habits.chain.legend_done") %></span>
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full border border-dashed border-[var(--color-border-default)]"></span><%= t("habits.chain.legend_missed") %></span>
          <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full border border-[var(--color-accent-400)]"></span><%= t("habits.chain.legend_today") %></span>
        </div>
      </div>

      <%# Stats %>
      <div class="grid grid-cols-3 gap-3">
        <div class="rounded-[var(--radius-sm)] border border-[var(--color-border-subtle)] bg-[var(--color-bg-overlay)] p-3">
          <p class="text-xs text-[var(--color-fg-muted)]"><%= t("habits.detail.current_streak") %></p>
          <p class="font-[family-name:var(--font-display)] text-2xl mt-1 flex items-center gap-1.5">
            <span class="text-[var(--color-warning)]"><%= render Ui::Icon.new(name: "flame", size: 18) %></span>
            <%= @habit.current_streak %>
          </p>
        </div>
        <div class="rounded-[var(--radius-sm)] border border-[var(--color-border-subtle)] bg-[var(--color-bg-overlay)] p-3">
          <p class="text-xs text-[var(--color-fg-muted)]"><%= t("habits.detail.longest") %></p>
          <p class="font-[family-name:var(--font-display)] text-2xl mt-1"><%= @habit.longest_streak %></p>
        </div>
        <div class="rounded-[var(--radius-sm)] border border-[var(--color-border-subtle)] bg-[var(--color-bg-overlay)] p-3">
          <p class="text-xs text-[var(--color-fg-muted)]"><%= t("habits.detail.rate_30d") %></p>
          <p class="font-[family-name:var(--font-display)] text-2xl mt-1"><%= @habit.completion_rate(days: 30) %>%</p>
        </div>
      </div>

      <%# 12-week chain — scrolls horizontally inside the modal %>
      <div>
        <h3 class="font-[family-name:var(--font-display)] text-lg tracking-tight mb-3"><%= t("habits.chain.window_84") %></h3>
        <div class="overflow-x-auto -mx-5 px-5">
          <%= render Ui::HabitChain.new(links: @habit.chain_window(days: 84), size: :xl, aria_label: t("habits.chain.aria", name: @habit.name)) %>
        </div>
      </div>
    </div>

    <div class="px-5 py-4 border-t border-[var(--color-border-subtle)] flex items-center justify-end gap-2">
      <%= link_to t("common.edit"), edit_habit_path(@habit), data: { turbo_frame: "modal" }, class: "px-3 py-2 text-sm border border-[var(--color-border-default)] rounded-[var(--radius-sm)] hover:bg-[var(--color-bg-hover)]" %>
      <%= button_to t("common.delete"), habit_path(@habit), method: :delete, data: { turbo_confirm: t("habits.delete_confirm"), turbo_frame: "_top" }, class: "px-3 py-2 text-sm border border-[var(--color-expense)] text-[var(--color-expense)] rounded-[var(--radius-sm)] hover:bg-[var(--color-bg-hover)] cursor-pointer" %>
    </div>
  </div>
</turbo-frame>
