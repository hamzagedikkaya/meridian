<%
  input_cls = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)]"
  label_cls = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
%>

<%= form_with model: entry, data: { turbo_frame: "_top" }, html: { class: "space-y-5", multipart: true } do |f| %>
  <% if entry.errors.any? %>
    <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
      <ul class="space-y-1 text-[var(--color-fg-muted)]"><% entry.errors.full_messages.each { |m| %><li>• <%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <%= f.label :date, t("journal.date"), class: label_cls %>
      <%= f.date_field :date, class: input_cls %>
    </div>
    <div>
      <%= f.label :title, t("common.name"), class: label_cls %>
      <%= f.text_field :title, placeholder: t("journal.title_optional"), class: input_cls %>
    </div>
  </div>

  <div>
    <label class="<%= label_cls %>"><%= t("journal.mood") %></label>
    <div class="flex gap-2">
      <% JournalEntry::MOODS.each do |m| %>
        <label class="cursor-pointer">
          <input type="radio" name="journal_entry[mood]" value="<%= m %>" <%= "checked" if entry.mood == m %> class="peer sr-only">
          <div class="w-12 h-12 rounded-full border-2 border-[var(--color-border-default)] peer-checked:border-[var(--color-accent-500)] peer-checked:bg-[var(--color-bg-overlay)] flex items-center justify-center text-2xl transition-colors">
            <%= JournalEntry::MOOD_EMOJI[m] %>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <%= f.label :energy_level, t("journal.energy"), class: label_cls %>
      <%= f.number_field :energy_level, min: 1, max: 5, class: input_cls %>
    </div>
    <div>
      <%= f.label :weather, t("journal.weather"), class: label_cls %>
      <%= f.text_field :weather, placeholder: t("journal.weather_placeholder"), class: input_cls %>
    </div>
  </div>

  <div>
    <%= f.label :body, t("journal.entry"), class: label_cls %>
    <div class="prose prose-invert max-w-none">
      <%= f.rich_text_area :body, class: "trix-content" %>
    </div>
  </div>

  <div>
    <%= f.label :gratitude, t("journal.gratitude_label"), class: label_cls %>
    <%= f.text_area :gratitude, rows: 3, placeholder: t("journal.gratitude_placeholder"), class: input_cls %>
  </div>

  <div>
    <%= f.label :tags, t("journal.tags"), class: label_cls %>
    <%= f.text_field :tags, placeholder: t("journal.tags_placeholder"), class: input_cls %>
  </div>

  <div class="flex justify-between items-center pt-4 border-t border-[var(--color-border-subtle)]">
    <a href="#" data-action="click->modal#close" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]"><%= t("common.cancel") %></a>
    <%= f.submit (entry.persisted? ? t("common.update") : t("journal.save")), class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] cursor-pointer" %>
  </div>
<% end %>
