<% content_for :page_title, t("journal.title") %>
<% content_for :nav_key, "journal" %>

<%
  range_options = JournalEntriesController::RANGES.map { |r| [ r, t("journal.range.#{r}") ] }
%>

<div class="space-y-6">
  <div class="flex items-end justify-between flex-wrap gap-3">
    <div>
      <h2 class="font-[family-name:var(--font-display)] text-4xl tracking-tight"><%= t("journal.title") %></h2>
      <p class="text-[var(--color-fg-muted)] mt-1">
        <%= @entries.size %> <%= t("journal.entries") %>
        <% if @journal_streak.to_i.positive? %>
          <span class="ml-2 text-[var(--color-warning)]">🔥 <%= t("journal.streak", count: @journal_streak) %></span>
        <% end %>
      </p>
    </div>
    <%= link_to t("journal.new_entry"), new_journal_entry_path, data: { turbo_frame: "modal" }, class: "px-3 py-2 text-sm bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] rounded-[var(--radius-sm)] font-medium" %>
  </div>

  <%# Range filter %>
  <nav class="flex flex-wrap items-center gap-1 p-1 bg-[var(--color-bg-elevated)] border border-[var(--color-border-subtle)] rounded-[var(--radius-sm)] w-fit">
    <% range_options.each do |key, label| %>
      <% is_active = @range == key %>
      <%= link_to label, journal_entries_path(range: key),
          class: "px-3 py-1.5 text-xs font-medium rounded-[var(--radius-sm)] transition-colors " +
                 (is_active ?
                   "bg-[var(--color-bg-overlay)] text-[var(--color-fg-primary)]" :
                   "text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]") %>
    <% end %>
  </nav>

  <% if @mood_data.any? %>
    <div class="card">
      <h3 class="font-[family-name:var(--font-display)] text-xl tracking-tight mb-4"><%= t("journal.mood_range", label: t("journal.range.#{@range}")) %></h3>
      <div class="flex gap-3 flex-wrap">
        <% JournalEntry::MOODS.each do |mood| %>
          <div class="flex items-center gap-2 text-sm">
            <span class="text-2xl"><%= JournalEntry::MOOD_EMOJI[mood] %></span>
            <span class="text-[var(--color-fg-muted)]"><%= @mood_data[mood] || 0 %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @entries.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      <% @entries.each do |entry| %>
        <%= link_to journal_entry_path(entry), class: "card hover:border-[var(--color-border-default)] aspect-square flex flex-col" do %>
          <div class="flex items-start justify-between gap-2 mb-3">
            <div>
              <p class="text-xs text-[var(--color-fg-muted)] uppercase tracking-wider"><%= l(entry.date, format: "%a") %></p>
              <p class="font-[family-name:var(--font-display)] text-2xl leading-none mt-0.5"><%= entry.date.day %></p>
              <p class="text-xs text-[var(--color-fg-muted)]"><%= l(entry.date, format: "%b %Y") %></p>
            </div>
            <% if entry.mood %>
              <span class="text-2xl flex-shrink-0"><%= entry.mood_emoji %></span>
            <% end %>
          </div>

          <div class="flex-1 min-h-0 overflow-hidden">
            <h3 class="text-sm font-medium line-clamp-1 mb-1"><%= entry.title.presence || t("journal.untitled") %></h3>
            <% if entry.body.body.present? %>
              <p class="text-xs text-[var(--color-fg-muted)] line-clamp-4"><%= truncate(entry.body.to_plain_text, length: 200) %></p>
            <% end %>
          </div>

          <% if entry.tag_list.any? %>
            <div class="flex gap-1 mt-3 flex-wrap">
              <% entry.tag_list.first(3).each do |tag| %><span class="pill !text-[10px]"><%= tag %></span><% end %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12">
      <p class="text-[var(--color-fg-muted)] mb-3"><%= t("journal.none") %></p>
      <%= link_to t("journal.write_today"), new_journal_entry_path, data: { turbo_frame: "modal" }, class: "text-[var(--color-accent-400)]" %>
    </div>
  <% end %>
</div>
