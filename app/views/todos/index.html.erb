<% content_for :page_title, t("todos.title") %>
<% content_for :nav_key, "todos" %>

<%
  filters = [
    [ "open",    t("todos.filters.open") ],
    [ "today",   t("todos.filters.today") ],
    [ "week",    t("todos.filters.week") ],
    [ "overdue", t("todos.filters.overdue") ],
    [ "done",    t("todos.filters.done") ]
  ]
  current_filter_label = t("todos.filters.#{@filter}", default: @filter.humanize)
%>

<div class="space-y-6">
  <div class="flex flex-wrap items-end justify-between gap-3">
    <div>
      <h2 class="font-[family-name:var(--font-display)] text-4xl tracking-tight"><%= t("todos.title") %></h2>
      <p class="text-[var(--color-fg-muted)] mt-1"><%= @todos.count %> <%= t("todos.tasks") %> · <em><%= current_filter_label %></em></p>
    </div>
    <div class="flex gap-2">
      <%= link_to t("todos.lists"), todo_lists_path, class: "px-3 py-2 text-sm border border-[var(--color-border-default)] rounded-[var(--radius-sm)] hover:bg-[var(--color-bg-hover)]" %>
      <%= link_to t("todos.new"), new_todo_path, data: { turbo_frame: "modal" }, class: "px-3 py-2 text-sm bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] rounded-[var(--radius-sm)] font-medium" %>
    </div>
  </div>

  <div class="flex gap-1 border-b border-[var(--color-border-subtle)] overflow-x-auto">
    <% filters.each do |key, label| %>
      <% active = @filter == key %>
      <%= link_to label, todos_path(filter: key), class: "px-4 py-2.5 text-sm border-b-2 transition-colors whitespace-nowrap " + (active ? "border-[var(--color-accent-500)] text-[var(--color-fg-primary)]" : "border-transparent text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]") %>
    <% end %>
  </div>

  <div class="card">
    <% if @todos.any? %>
      <ul class="divide-y divide-[var(--color-border-subtle)]">
        <% @todos.each do |todo| %>
          <%= render todo %>
        <% end %>
      </ul>
    <% else %>
      <div class="text-center py-10">
        <p class="text-[var(--color-fg-muted)]"><%= t("todos.none", filter: current_filter_label) %></p>
        <%= link_to t("todos.add_one"), new_todo_path, data: { turbo_frame: "modal" }, class: "mt-2 inline-block text-[var(--color-accent-400)]" %>
      </div>
    <% end %>
  </div>
</div>
