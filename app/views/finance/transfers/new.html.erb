<% content_for :page_title, "Transfer" %>
<% content_for :nav_key, "finance" %>

<%
  input_cls = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)]"
  label_cls = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
%>

<div class="max-w-xl space-y-4">
  <%= link_to "← Back", finance_root_path, class: "text-sm text-[var(--color-fg-muted)]" %>
  <h2 class="font-[family-name:var(--font-display)] text-3xl tracking-tight">Transfer between accounts</h2>

  <div class="card">
    <%= form_with url: finance_transfer_path, method: :post, html: { class: "space-y-5" } do |f| %>
      <div>
        <%= label_tag :from_account_id, "From", class: label_cls %>
        <%= select_tag :from_account_id, options_for_select(@accounts.map { |a| [ a.name, a.id ] }), class: input_cls, prompt: "Select…" %>
      </div>
      <div>
        <%= label_tag :to_account_id, "To", class: label_cls %>
        <%= select_tag :to_account_id, options_for_select(@accounts.map { |a| [ a.name, a.id ] }), class: input_cls, prompt: "Select…" %>
      </div>
      <div>
        <%= label_tag :amount, "Amount", class: label_cls %>
        <%= number_field_tag :amount, nil, step: 0.01, min: 0, class: input_cls %>
      </div>
      <div>
        <%= label_tag :date, class: label_cls %>
        <%= date_field_tag :date, Date.current, class: input_cls %>
      </div>
      <div>
        <%= label_tag :description, class: label_cls %>
        <%= text_field_tag :description, nil, class: input_cls %>
      </div>
      <div>
        <%= label_tag :note, class: label_cls %>
        <%= text_area_tag :note, nil, rows: 2, class: input_cls %>
      </div>
      <div class="flex justify-between items-center pt-4 border-t border-[var(--color-border-subtle)]">
        <%= link_to "Cancel", finance_root_path, class: "text-sm text-[var(--color-fg-muted)]" %>
        <%= submit_tag "Transfer", class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
