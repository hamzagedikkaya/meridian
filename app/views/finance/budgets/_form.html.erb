<%
  input_cls = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)]"
  label_cls = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
  subunit = Money::Currency.find(current_user.currency)&.subunit_to_unit || 100
  limit_value = budget.monthly_limit_cents.to_i.positive? ? (budget.monthly_limit_cents / subunit.to_f) : nil
%>

<%= form_with model: budget,
              url: (budget.persisted? ? finance_budget_path(budget) : finance_budgets_path),
              data: { turbo_frame: "_top" },
              html: { class: "space-y-5" } do |f| %>
  <% if budget.errors.any? %>
    <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
      <ul class="space-y-1 text-[var(--color-fg-muted)]"><% budget.errors.full_messages.each { |m| %><li>• <%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div>
    <%= f.label :finance_category_id, t("finance.budgets.category"), class: label_cls %>
    <%= render Ui::CategoryPicker.new(
          name: "budget[finance_category_id]",
          categories: budgetable_categories,
          selected_id: budget.finance_category_id,
          blank_label: t("finance.budgets.choose_category"),
          input_class: input_cls) %>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <%= label_tag "budget_monthly_limit", t("finance.budgets.monthly_limit"), class: label_cls %>
      <div class="relative">
        <%= number_field_tag "budget[monthly_limit]", limit_value, step: "0.01", min: 0, id: "budget_monthly_limit",
              placeholder: "0", class: input_cls + " pr-12 tabular-nums" %>
        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-[var(--color-fg-muted)] pointer-events-none"><%= current_user.currency %></span>
      </div>
    </div>
    <div>
      <%= f.label :color, t("common.color"), class: label_cls %>
      <%= render "shared/color_picker", form: f, input_class: input_cls %>
    </div>
  </div>

  <p class="text-xs text-[var(--color-fg-faint)]"><%= t("finance.budgets.form_hint") %></p>

  <div class="flex justify-between items-center pt-4 border-t border-[var(--color-border-subtle)]">
    <a href="#" data-action="click->modal#close" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]"><%= t("common.cancel") %></a>
    <%= f.submit (budget.persisted? ? t("common.update") : t("common.create")), class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] cursor-pointer" %>
  </div>
<% end %>
