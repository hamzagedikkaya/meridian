<% content_for :page_title, @subscription.name %>
<% content_for :nav_key, "finance" %>

<div class="max-w-xl space-y-4">
  <%= link_to t("common.back"), finance_subscriptions_path, class: "text-sm text-[var(--color-fg-muted)]" %>
  <div class="card">
    <p class="text-sm text-[var(--color-fg-muted)] uppercase tracking-wider"><%= @subscription.frequency.titleize %></p>
    <h2 class="font-[family-name:var(--font-display)] text-3xl tracking-tight mt-1"><%= @subscription.name %></h2>
    <p class="stat-number mt-4 text-[var(--color-expense)]"><%= money_format(@subscription.amount_cents, currency: @subscription.account_currency) %></p>
    <p class="text-sm text-[var(--color-fg-muted)] mt-1"><%= money_format(@subscription.yearly_amount_cents, currency: @subscription.account_currency) %> <%= t("finance.subscriptions.yearly") %></p>

    <dl class="grid grid-cols-2 gap-3 mt-6 text-sm">
      <div><dt class="text-[var(--color-fg-muted)]"><%= t("common.account") %></dt><dd><%= @subscription.account.name %></dd></div>
      <div><dt class="text-[var(--color-fg-muted)]"><%= t("finance.subscriptions.next_charge_on") %></dt><dd><%= @subscription.next_charge_on ? l(@subscription.next_charge_on, format: "%d %b %Y") : t("common.none") %></dd></div>
      <% if @subscription.vendor.present? %><div><dt class="text-[var(--color-fg-muted)]"><%= t("finance.subscriptions.vendor") %></dt><dd><%= @subscription.vendor %></dd></div><% end %>
      <div><dt class="text-[var(--color-fg-muted)]"><%= t("common.status") %></dt><dd><%= @subscription.active? ? t("finance.subscriptions.active") : t("finance.subscriptions.inactive") %></dd></div>
    </dl>
  </div>
</div>
