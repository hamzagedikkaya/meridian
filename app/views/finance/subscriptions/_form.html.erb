<%
  input_cls = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)]"
  label_cls = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
%>

<%= form_with model: [ :finance, subscription ], data: { turbo_frame: "_top" }, html: { class: "space-y-5" } do |f| %>
  <% if subscription.errors.any? %>
    <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
      <ul class="space-y-1 text-[var(--color-fg-muted)]"><% subscription.errors.full_messages.each { |m| %><li>• <%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <%= f.label :name, t("common.name"), class: label_cls %>
      <%= f.text_field :name, class: input_cls %>
    </div>
    <div>
      <%= f.label :vendor, t("finance.subscriptions.vendor"), class: label_cls %>
      <%= f.text_field :vendor, placeholder: t("finance.subscriptions.vendor_placeholder"), class: input_cls %>
    </div>
    <div>
      <%= f.label :amount, t("common.amount"), class: label_cls %>
      <%= number_field_tag "subscription[amount]", subscription.amount_cents.to_i / 100.0, step: 0.01, min: 0, class: input_cls %>
    </div>
    <div>
      <%= f.label :frequency, t("finance.subscriptions.frequency"), class: label_cls %>
      <%= f.select :frequency, Subscription::FREQUENCIES.map { |fr| [ t("enums.frequency.#{fr}"), fr ] }, {}, class: input_cls %>
    </div>
    <div>
      <%= f.label :account_id, t("common.account"), class: label_cls %>
      <%= render Ui::CategoryPicker.new(
            name: "subscription[account_id]",
            categories: @accounts,
            selected_id: subscription.account_id,
            blank_label: t("common.optional") + "…",
            input_class: input_cls
          ) %>
    </div>
    <div>
      <%= f.label :finance_category_id, t("common.category"), class: label_cls %>
      <%= render Ui::CategoryPicker.new(
            name: "subscription[finance_category_id]",
            categories: @categories,
            selected_id: subscription.finance_category_id,
            blank_label: t("common.optional") + "…",
            input_class: input_cls
          ) %>
    </div>
    <div>
      <%= f.label :start_date, t("finance.subscriptions.start_date"), class: label_cls %>
      <%= f.date_field :start_date, class: input_cls %>
    </div>
    <div>
      <%= f.label :next_charge_on, t("finance.subscriptions.next_charge_on"), class: label_cls %>
      <%= f.date_field :next_charge_on, class: input_cls %>
    </div>
    <div>
      <%= f.label :end_date, t("finance.subscriptions.end_date"), class: label_cls %>
      <%= f.date_field :end_date, class: input_cls %>
    </div>
    <div>
      <%= f.label :color, t("common.color"), class: label_cls %>
      <%= f.color_field :color, class: input_cls + " h-10" %>
    </div>
  </div>

  <label class="flex items-center gap-2 text-sm">
    <%= f.check_box :active, class: "w-4 h-4 rounded bg-[var(--color-bg-elevated)] border-[var(--color-border-default)]" %>
    <span><%= t("finance.subscriptions.active") %></span>
  </label>

  <div class="flex justify-between items-center pt-4 border-t border-[var(--color-border-subtle)]">
    <a href="#" data-action="click->modal#close" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]"><%= t("common.cancel") %></a>
    <%= f.submit (subscription.persisted? ? t("common.update") : t("common.create")), class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] cursor-pointer" %>
  </div>
<% end %>
