<%
  input_cls = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)]"
  label_cls = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
%>

<%= form_with model: [ :finance, subscription ], html: { class: "space-y-5" } do |f| %>
  <% if subscription.errors.any? %>
    <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
      <ul class="space-y-1 text-[var(--color-fg-muted)]"><% subscription.errors.full_messages.each { |m| %><li>• <%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <%= f.label :name, class: label_cls %>
      <%= f.text_field :name, class: input_cls %>
    </div>
    <div>
      <%= f.label :vendor, class: label_cls %>
      <%= f.text_field :vendor, placeholder: "Netflix, Spotify…", class: input_cls %>
    </div>
    <div>
      <%= f.label :amount, class: label_cls %>
      <%= number_field_tag "subscription[amount]", subscription.amount_cents.to_i / 100.0, step: 0.01, min: 0, class: input_cls %>
    </div>
    <div>
      <%= f.label :frequency, class: label_cls %>
      <%= f.select :frequency, Subscription::FREQUENCIES.map { |fr| [ fr.titleize, fr ] }, {}, class: input_cls %>
    </div>
    <div>
      <%= f.label :account_id, "Account", class: label_cls %>
      <%= f.select :account_id, @accounts.map { |a| [ a.name, a.id ] }, { prompt: "Select…" }, class: input_cls %>
    </div>
    <div>
      <%= f.label :finance_category_id, "Category", class: label_cls %>
      <%= f.select :finance_category_id, @categories.map { |c| [ c.name, c.id ] }, { include_blank: true }, class: input_cls %>
    </div>
    <div>
      <%= f.label :start_date, class: label_cls %>
      <%= f.date_field :start_date, class: input_cls %>
    </div>
    <div>
      <%= f.label :next_charge_on, class: label_cls %>
      <%= f.date_field :next_charge_on, class: input_cls %>
    </div>
    <div>
      <%= f.label :end_date, class: label_cls %>
      <%= f.date_field :end_date, class: input_cls %>
    </div>
    <div>
      <%= f.label :color, class: label_cls %>
      <%= f.color_field :color, class: input_cls + " h-10" %>
    </div>
  </div>

  <label class="flex items-center gap-2 text-sm">
    <%= f.check_box :active, class: "w-4 h-4 rounded bg-[var(--color-bg-elevated)] border-[var(--color-border-default)]" %>
    <span>Active</span>
  </label>

  <div class="flex justify-between items-center pt-4 border-t border-[var(--color-border-subtle)]">
    <%= link_to "Cancel", finance_subscriptions_path, class: "text-sm text-[var(--color-fg-muted)]" %>
    <%= f.submit (subscription.persisted? ? "Update" : "Create"), class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] cursor-pointer" %>
  </div>
<% end %>
