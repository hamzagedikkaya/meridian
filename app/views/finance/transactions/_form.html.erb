<%
  input_cls = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors"
  label_cls = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
  kind_labels = { "income" => t("finance.dashboard.income"), "expense" => t("finance.dashboard.expense") }
  all_categories = (@income_categories + @expense_categories).sort_by { |c| [ c.kind, c.name.downcase ] }
%>

<%= form_with model: [ :finance, transaction ], data: { turbo_frame: "_top", controller: "transaction-form" }, html: { class: "space-y-5" } do |f| %>
  <% if transaction.errors.any? %>
    <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
      <ul class="space-y-1 text-[var(--color-fg-muted)]">
        <% transaction.errors.full_messages.each do |msg| %>
          <li>• <%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex gap-2">
    <% %w[income expense].each do |k| %>
      <label class="flex-1 cursor-pointer">
        <input type="radio" name="transaction[kind]" value="<%= k %>" <%= "checked" if transaction.kind == k %> class="peer sr-only" data-transaction-form-target="kindRadio" data-action="change->transaction-form#kindChanged">
        <div class="px-4 py-2.5 text-center text-sm rounded-[var(--radius-sm)] border border-[var(--color-border-default)] peer-checked:border-[var(--color-accent-500)] peer-checked:bg-[var(--color-bg-overlay)] peer-checked:text-[var(--color-fg-primary)] text-[var(--color-fg-muted)] transition-colors">
          <%= kind_labels[k] %>
        </div>
      </label>
    <% end %>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <%= f.label :amount, t("finance.transactions.amount"), class: label_cls %>
      <%= number_field_tag "transaction[amount]", transaction.amount_cents.to_i / 100.0, step: 0.01, min: 0, class: input_cls %>
    </div>

    <div>
      <%= f.label :date, t("finance.transactions.date"), class: label_cls %>
      <%= f.date_field :date, class: input_cls %>
    </div>

    <div>
      <div class="flex items-center justify-between mb-1.5">
        <%= f.label :account_id, t("finance.transactions.account"), class: "text-sm font-medium text-[var(--color-fg-muted)]" %>
        <%= link_to t("finance.transactions.manage_accounts"), finance_accounts_path, data: { turbo_frame: "_top" }, class: "text-xs text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
      </div>
      <%= render Ui::CategoryPicker.new(
            name: "transaction[account_id]",
            categories: @accounts,
            selected_id: transaction.account_id,
            blank_label: t("common.optional") + "…",
            input_class: input_cls
          ) %>
    </div>

    <div>
      <div class="flex items-center justify-between mb-1.5">
        <%= f.label :finance_category_id, t("finance.transactions.category"), class: "text-sm font-medium text-[var(--color-fg-muted)]" %>
        <%= link_to t("finance.transactions.manage_categories"), finance_categories_path, data: { turbo_frame: "_top" }, class: "text-xs text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
      </div>
      <%= render Ui::CategoryPicker.new(
            name: "transaction[finance_category_id]",
            categories: all_categories,
            selected_id: transaction.finance_category_id,
            blank_label: t("common.optional") + "…",
            extra_data: { "transaction-form-target": "categoryPicker" },
            input_class: input_cls
          ) %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :description, t("finance.transactions.description"), class: label_cls %>
      <%= f.text_field :description, class: input_cls %>
    </div>
  </div>

  <% unless transaction.persisted? %>
    <div class="pt-3 border-t border-[var(--color-border-subtle)]">
      <label class="flex items-center gap-2 cursor-pointer select-none">
        <input type="checkbox" name="transaction[linked][enabled]" value="1" class="rounded border-[var(--color-border-default)]" data-transaction-form-target="linkedToggle" data-action="change->transaction-form#linkedToggled">
        <span class="text-sm font-medium text-[var(--color-fg-primary)]"><%= t("finance.transactions.linked.toggle") %></span>
      </label>
      <p class="text-xs text-[var(--color-fg-muted)] mt-1"><%= t("finance.transactions.linked.hint") %></p>

      <fieldset class="hidden mt-4 p-4 rounded-[var(--radius-md)] border border-[var(--color-border-subtle)] bg-[var(--color-bg-overlay)] space-y-4" data-transaction-form-target="linkedSection" disabled>
        <p class="text-xs uppercase tracking-wider text-[var(--color-fg-muted)]"
           data-transaction-form-target="linkedKindLabel"
           data-label-income="<%= t("finance.dashboard.income") %>"
           data-label-expense="<%= t("finance.dashboard.expense") %>"></p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="<%= label_cls %>"><%= t("finance.transactions.amount") %></label>
            <input type="number" step="0.01" min="0" name="transaction[linked][amount]" class="<%= input_cls %>">
          </div>
          <div>
            <label class="<%= label_cls %>"><%= t("finance.transactions.account") %></label>
            <%= render Ui::CategoryPicker.new(
                  name: "transaction[linked][account_id]",
                  categories: @accounts,
                  blank_label: t("common.optional") + "…",
                  input_class: input_cls
                ) %>
          </div>
          <div class="md:col-span-2">
            <label class="<%= label_cls %>"><%= t("finance.transactions.category") %></label>
            <%= render Ui::CategoryPicker.new(
                  name: "transaction[linked][finance_category_id]",
                  categories: all_categories,
                  blank_label: t("common.optional") + "…",
                  extra_data: { "transaction-form-target": "linkedCategoryPicker" },
                  input_class: input_cls
                ) %>
          </div>
        </div>
      </fieldset>
    </div>
  <% end %>

  <div class="flex items-center justify-between pt-4 border-t border-[var(--color-border-subtle)]">
    <a href="#" data-action="click->modal#close" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]"><%= t("common.cancel") %></a>
    <%= f.submit (transaction.persisted? ? t("finance.transactions.update") : t("finance.transactions.save")), class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] transition-colors cursor-pointer" %>
  </div>
<% end %>
