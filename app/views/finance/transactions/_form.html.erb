<%
  input_cls = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors"
  label_cls = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
%>

<%= form_with model: [ :finance, transaction ], html: { class: "space-y-5" } do |f| %>
  <% if transaction.errors.any? %>
    <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
      <ul class="space-y-1 text-[var(--color-fg-muted)]">
        <% transaction.errors.full_messages.each do |msg| %>
          <li>• <%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex gap-2">
    <% %w[income expense].each do |k| %>
      <label class="flex-1 cursor-pointer">
        <input type="radio" name="transaction[kind]" value="<%= k %>" <%= "checked" if transaction.kind == k %> class="peer sr-only">
        <div class="px-4 py-2.5 text-center text-sm rounded-[var(--radius-sm)] border border-[var(--color-border-default)] peer-checked:border-[var(--color-accent-500)] peer-checked:bg-[var(--color-bg-overlay)] peer-checked:text-[var(--color-fg-primary)] text-[var(--color-fg-muted)] transition-colors">
          <%= k.titleize %>
        </div>
      </label>
    <% end %>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <%= f.label :amount, class: label_cls %>
      <%= number_field_tag "transaction[amount]", transaction.amount_cents.to_i / 100.0, step: 0.01, min: 0, class: input_cls %>
    </div>

    <div>
      <%= f.label :date, class: label_cls %>
      <%= f.date_field :date, class: input_cls %>
    </div>

    <div>
      <%= f.label :account_id, "Account", class: label_cls %>
      <%= f.select :account_id, @accounts.map { |a| [ a.name, a.id ] }, { prompt: "Select…" }, class: input_cls %>
    </div>

    <div>
      <%= f.label :finance_category_id, "Category", class: label_cls %>
      <%= f.select :finance_category_id, (@income_categories + @expense_categories).map { |c| [ "#{c.name} (#{c.kind})", c.id ] }, { include_blank: true }, class: input_cls %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :description, class: label_cls %>
      <%= f.text_field :description, class: input_cls %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :note, class: label_cls %>
      <%= f.text_area :note, rows: 2, class: input_cls %>
    </div>
  </div>

  <div class="flex items-center justify-between pt-4 border-t border-[var(--color-border-subtle)]">
    <%= link_to "Cancel", finance_transactions_path, class: "text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]" %>
    <%= f.submit (transaction.persisted? ? "Update" : "Save"), class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] transition-colors cursor-pointer" %>
  </div>
<% end %>
