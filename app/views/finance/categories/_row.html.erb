<li class="flex items-center justify-between gap-3 px-2 py-1.5 rounded-[var(--radius-sm)] hover:bg-[var(--color-bg-hover)]<%= " pl-7" if depth.positive? %>">
  <div class="flex items-center gap-2 min-w-0">
    <% if depth.positive? %>
      <span class="text-[var(--color-fg-muted)] text-xs">└</span>
    <% end %>
    <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background: <%= category.color %>;"></span>
    <span class="text-sm truncate"><%= category.name %></span>
  </div>
  <div class="flex items-center gap-4 text-xs">
    <% if count.to_i.positive? %>
      <div class="flex items-center gap-2 text-[var(--color-fg-muted)]">
        <span class="tabular-nums"><%= t("finance.categories.month_transactions", count: count) %></span>
        <span class="text-[var(--color-fg-primary)] font-medium tabular-nums"><%= money_format(total_cents, currency: currency) %></span>
      </div>
    <% end %>
    <div class="flex gap-2">
      <%= link_to t("common.edit"), edit_finance_category_path(category), data: { turbo_frame: "modal" }, class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
      <%= button_to "×", finance_category_path(category), method: :delete, data: { turbo_confirm: t("finance.categories.delete_confirm") }, class: "text-[var(--color-expense)] hover:text-[var(--color-fg-primary)] cursor-pointer" %>
    </div>
  </div>
</li>
