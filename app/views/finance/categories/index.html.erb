<% content_for :page_title, t("finance.categories.title") %>
<% content_for :nav_key, "finance" %>

<div class="space-y-6">
  <div class="flex items-end justify-between gap-3">
    <div>
      <h2 class="font-[family-name:var(--font-display)] text-4xl tracking-tight"><%= t("finance.categories.title") %></h2>
      <p class="text-[var(--color-fg-muted)] mt-1"><%= t("finance.categories.subtitle") %> <span class="text-[var(--color-fg-faint)]"><%= t("finance.categories.month_subtitle") %></span></p>
    </div>
    <div class="flex gap-2">
      <%= link_to t("finance.categories.new_income"), new_finance_category_path(kind: "income"), data: { turbo_frame: "modal" }, class: "px-3 py-2 text-sm border border-[var(--color-income)] text-[var(--color-income)] rounded-[var(--radius-sm)] hover:bg-[var(--color-bg-hover)]" %>
      <%= link_to t("finance.categories.new_expense"), new_finance_category_path(kind: "expense"), data: { turbo_frame: "modal" }, class: "px-3 py-2 text-sm border border-[var(--color-expense)] text-[var(--color-expense)] rounded-[var(--radius-sm)] hover:bg-[var(--color-bg-hover)]" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% [ [ t("finance.dashboard.income"), @income_categories, "income" ], [ t("finance.dashboard.expense"), @expense_categories, "expense" ] ].each do |label, cats, kind| %>
      <div class="card">
        <h3 class="font-[family-name:var(--font-display)] text-xl tracking-tight mb-4"><%= label %></h3>
        <% if cats.any? %>
          <ul class="space-y-1">
            <% cats.each do |c| %>
              <%
                own = @month_stats[c.id] || { count: 0, total_cents: 0 }
                children = c.children.sort_by { |ch| ch.name.downcase }
                combined_count = own[:count] + children.sum { |ch| (@month_stats[ch.id] || {})[:count].to_i }
                combined_total = own[:total_cents] + children.sum { |ch| (@month_stats[ch.id] || {})[:total_cents].to_i }
              %>
              <%= render "row", category: c, depth: 0, count: combined_count, total_cents: combined_total, currency: @currency %>
              <% children.each do |child| %>
                <% child_stats = @month_stats[child.id] || { count: 0, total_cents: 0 } %>
                <%= render "row", category: child, depth: 1, count: child_stats[:count], total_cents: child_stats[:total_cents], currency: @currency %>
              <% end %>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-[var(--color-fg-muted)]"><%= t("finance.categories.none", kind: label.downcase) %></p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
