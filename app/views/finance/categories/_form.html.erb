<%
  input_cls = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)]"
  label_cls = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
  kind_labels = { "income" => t("finance.dashboard.income"), "expense" => t("finance.dashboard.expense") }
%>

<%= form_with model: category,
              url: (category.persisted? ? finance_category_path(category) : finance_categories_path),
              data: { turbo_frame: "_top" },
              html: { class: "space-y-5" } do |f| %>
  <% if category.errors.any? %>
    <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
      <ul class="space-y-1 text-[var(--color-fg-muted)]"><% category.errors.full_messages.each { |m| %><li>• <%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <%= f.label :name, t("common.name"), class: label_cls %>
      <%= f.text_field :name, class: input_cls %>
    </div>
    <div>
      <%= f.label :kind, t("common.type"), class: label_cls %>
      <%= f.select :kind, FinanceCategory::KINDS.map { |k| [ kind_labels[k], k ] }, {}, class: input_cls %>
    </div>
    <div>
      <%= f.label :color, t("common.color"), class: label_cls %>
      <%= f.color_field :color, class: input_cls + " h-10" %>
    </div>
    <div>
      <%= f.label :icon, t("common.icon"), class: label_cls %>
      <%= f.text_field :icon, class: input_cls %>
    </div>
  </div>

  <div class="flex justify-between items-center pt-4 border-t border-[var(--color-border-subtle)]">
    <a href="#" data-action="click->modal#close" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]"><%= t("common.cancel") %></a>
    <%= f.submit (category.persisted? ? t("common.update") : t("common.create")), class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] cursor-pointer" %>
  </div>
<% end %>
