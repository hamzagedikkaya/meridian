<% content_for :page_title, @account.name %>
<% content_for :nav_key, "finance" %>

<div class="max-w-3xl space-y-6">
  <%= link_to "← Accounts", finance_accounts_path, class: "text-sm text-[var(--color-fg-muted)]" %>

  <div class="card">
    <div class="flex items-start justify-between gap-3">
      <div>
        <p class="text-sm text-[var(--color-fg-muted)] uppercase tracking-wider"><%= @account.account_type.titleize %></p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl tracking-tight mt-1"><%= @account.name %></h2>
      </div>
      <div class="flex gap-2">
        <%= link_to "Edit", edit_finance_account_path(@account), class: "px-3 py-2 text-sm border border-[var(--color-border-default)] rounded-[var(--radius-sm)] hover:bg-[var(--color-bg-hover)]" %>
        <%= button_to "Delete", finance_account_path(@account), method: :delete, data: { turbo_confirm: "Delete this account? Transactions will also be deleted." }, class: "px-3 py-2 text-sm border border-[var(--color-expense)] text-[var(--color-expense)] rounded-[var(--radius-sm)] hover:bg-[var(--color-bg-hover)] cursor-pointer" %>
      </div>
    </div>
    <p class="stat-number mt-6"><%= money_format(@account.balance_cents, currency: @account.currency) %></p>
    <p class="text-xs text-[var(--color-fg-faint)] mt-1">Current balance · <%= @account.currency %></p>
  </div>

  <div class="card">
    <h3 class="font-[family-name:var(--font-display)] text-xl tracking-tight mb-4">Recent transactions</h3>
    <% if @transactions.any? %>
      <ul class="divide-y divide-[var(--color-border-subtle)]">
        <% @transactions.each do |t| %>
          <li class="py-3 flex items-center justify-between gap-3">
            <div class="min-w-0">
              <p class="text-sm truncate"><%= t.description.presence || t.finance_category&.name || t.kind.titleize %></p>
              <p class="text-xs text-[var(--color-fg-muted)]"><%= t.date.strftime("%d %b %Y") %></p>
            </div>
            <span class="text-sm font-medium <%= signed_amount_class(t.kind) %>"><%= signed_amount_prefix(t.kind) %><%= money_format(t.amount_cents, currency: t.account_currency) %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-[var(--color-fg-muted)]">No transactions yet.</p>
    <% end %>
  </div>
</div>
