<% content_for :page_title, t("finance.accounts.title") %>
<% content_for :nav_key, "finance" %>

<div class="space-y-6">
  <div class="flex items-end justify-between gap-3">
    <div>
      <h2 class="font-[family-name:var(--font-display)] text-4xl tracking-tight"><%= t("finance.accounts.title") %></h2>
      <p class="text-[var(--color-fg-muted)] mt-1"><%= t("finance.accounts.subtitle") %></p>
    </div>
    <%= link_to t("finance.accounts.new"), new_finance_account_path, data: { turbo_frame: "modal" }, class: "px-3 py-2 text-sm bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] rounded-[var(--radius-sm)] font-medium" %>
  </div>

  <% if @accounts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @accounts.each do |acc| %>
        <%= link_to finance_account_path(acc), class: "card hover:border-[var(--color-border-default)] block #{'opacity-60' if acc.archived?}" do %>
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-sm text-[var(--color-fg-muted)]"><%= acc.account_type.titleize %></p>
              <p class="text-lg font-medium mt-1 truncate"><%= acc.name %></p>
            </div>
            <span class="w-3 h-3 rounded-full flex-shrink-0 mt-1.5" style="background: <%= acc.color %>;"></span>
          </div>
          <p class="stat-number mt-4 !text-3xl"><%= money_format(acc.balance_cents, currency: acc.currency) %></p>
          <p class="text-xs text-[var(--color-fg-faint)] mt-1"><%= acc.currency %><%= " · #{t('common.archived')}" if acc.archived? %></p>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12">
      <p class="text-[var(--color-fg-muted)] mb-3"><%= t("finance.accounts.none") %></p>
      <%= link_to t("finance.accounts.create_first"), new_finance_account_path, data: { turbo_frame: "modal" }, class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
    </div>
  <% end %>
</div>
