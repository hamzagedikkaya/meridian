<% content_for :page_title, t("settings.title") %>

<%
  input_class = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors"
  label_class = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
  hint_class  = "mt-1 text-xs text-[var(--color-fg-faint)]"

  weekly_days = (0..6).map { |i| [ l(Date.new(2026, 1, 4) + i.days, format: "%A"), i ] }
%>

<%= render layout: "shell" do %>
  <section class="card">
    <header class="mb-6">
      <h2 class="font-[family-name:var(--font-display)] text-2xl tracking-tight"><%= t("settings.preferences.title") %></h2>
      <p class="text-sm text-[var(--color-fg-muted)] mt-1"><%= t("settings.preferences.subtitle") %></p>
    </header>

    <%= form_with model: current_user, url: preferences_settings_path, method: :patch, html: { class: "space-y-6" } do |f| %>
      <% if current_user.errors.any? %>
        <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
          <ul class="space-y-1 text-[var(--color-fg-muted)]">
            <% current_user.errors.full_messages.each do |msg| %>
              <li>• <%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <%= f.label :timezone, t("settings.preferences.timezone"), class: label_class %>
          <%= f.time_zone_select :timezone, ActiveSupport::TimeZone.all, {}, class: input_class %>
          <p class="<%= hint_class %>"><%= t("settings.preferences.timezone_hint") %></p>
        </div>

        <div>
          <%= f.label :currency, t("settings.preferences.currency"), class: label_class %>
          <%= f.text_field :currency, maxlength: 3,
              class: input_class + " uppercase font-mono",
              style: "text-transform: uppercase;" %>
          <p class="<%= hint_class %>"><%= t("settings.preferences.currency_hint") %></p>
        </div>

        <div>
          <%= f.label :locale, t("settings.preferences.locale"), class: label_class %>
          <%= f.select :locale, [ [ "Türkçe", "tr" ], [ "English", "en" ] ], {}, class: input_class %>
        </div>

        <div>
          <%= f.label :theme_preference, t("settings.preferences.theme"), class: label_class %>
          <%= f.select :theme_preference,
              [ [ t("settings.preferences.theme_dark"), "dark" ], [ t("settings.preferences.theme_light"), "light" ], [ t("settings.preferences.theme_system"), "system" ] ],
              {},
              class: input_class %>
        </div>

        <div class="md:col-span-2">
          <%= f.label :weekly_review_day, t("settings.preferences.weekly_review_day"), class: label_class %>
          <%= f.select :weekly_review_day, weekly_days, {}, class: input_class %>
          <p class="<%= hint_class %>"><%= t("settings.preferences.weekly_review_day_hint") %></p>
        </div>
      </div>

      <div class="flex items-center justify-end pt-4 border-t border-[var(--color-border-subtle)]">
        <%= f.submit t("settings.preferences.save"),
            class: "px-5 py-2.5 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </section>
<% end %>
