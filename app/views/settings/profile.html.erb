<% content_for :page_title, t("settings.title") %>

<%
  input_class = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors"
  label_class = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
  hint_class  = "mt-1 text-xs text-[var(--color-fg-faint)]"
%>

<%= render layout: "shell" do %>
  <%= form_with model: current_user, url: profile_settings_path, method: :patch, html: { class: "space-y-6", multipart: true } do |f| %>
    <% if current_user.errors.any? %>
      <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
        <p class="font-medium text-[var(--color-danger)] mb-2"><%= t("auth.please_fix") %></p>
        <ul class="space-y-1 text-[var(--color-fg-muted)]">
          <% current_user.errors.full_messages.each do |msg| %>
            <li>• <%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Identity card — avatar + name + email %>
    <section class="card">
      <header class="mb-5">
        <h2 class="font-[family-name:var(--font-display)] text-2xl tracking-tight"><%= t("settings.profile.title") %></h2>
        <p class="text-sm text-[var(--color-fg-muted)] mt-1"><%= t("settings.profile.subtitle") %></p>
      </header>

      <div class="flex items-center gap-5 pb-6 mb-6 border-b border-[var(--color-border-subtle)]">
        <div class="w-20 h-20 rounded-full bg-[var(--color-accent-700)] flex items-center justify-center text-2xl font-medium overflow-hidden flex-shrink-0">
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar, class: "w-full h-full object-cover" %>
          <% else %>
            <%= current_user.initials %>
          <% end %>
        </div>
        <div class="min-w-0">
          <%= f.label :avatar, t("settings.profile.avatar"), class: label_class %>
          <%= f.file_field :avatar, accept: "image/*", class: "text-sm text-[var(--color-fg-muted)] file:mr-3 file:px-3 file:py-1.5 file:rounded-[var(--radius-sm)] file:border-0 file:bg-[var(--color-bg-overlay)] file:text-[var(--color-fg-primary)] file:cursor-pointer hover:file:bg-[var(--color-bg-hover)]" %>
          <p class="<%= hint_class %>"><%= t("settings.profile.avatar_hint") %></p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <%= f.label :name, t("common.name"), class: label_class %>
          <%= f.text_field :name, class: input_class %>
        </div>

        <div>
          <%= f.label :email, class: label_class %>
          <%= f.email_field :email, class: input_class %>
        </div>
      </div>
    </section>

    <%# Password card — collapsed by default %>
    <section class="card" data-controller="reveal">
      <header class="flex items-center justify-between mb-2">
        <div>
          <h2 class="font-[family-name:var(--font-display)] text-xl tracking-tight flex items-center gap-2">
            <span class="text-[var(--color-fg-muted)]"><%= render Ui::Icon.new(name: "lock", size: 18) %></span>
            <%= t("settings.profile.password_title") %>
          </h2>
          <p class="text-sm text-[var(--color-fg-muted)] mt-1"><%= t("settings.profile.password_hint") %></p>
        </div>
        <button type="button"
                data-action="reveal#toggle"
                data-reveal-target="trigger"
                class="text-sm text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)] cursor-pointer">
          <span data-reveal-target="showLabel"><%= t("settings.profile.change_password") %></span>
          <span data-reveal-target="hideLabel" class="hidden"><%= t("common.cancel") %></span>
        </button>
      </header>

      <div data-reveal-target="content" class="hidden mt-5 pt-5 border-t border-[var(--color-border-subtle)] grid md:grid-cols-2 gap-5">
        <div>
          <%= f.label :password, t("settings.profile.new_password"), class: label_class %>
          <%= f.password_field :password, autocomplete: "new-password", class: input_class %>
          <p class="<%= hint_class %>"><%= t("settings.profile.password_min", min: Devise.password_length.min) %></p>
        </div>
        <div>
          <%= f.label :password_confirmation, t("settings.profile.confirm_password"), class: label_class %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: input_class %>
        </div>
      </div>
    </section>

    <div class="flex items-center justify-end">
      <%= f.submit t("common.save_changes"),
          class: "px-5 py-2.5 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] transition-colors cursor-pointer" %>
    </div>
  <% end %>
<% end %>
