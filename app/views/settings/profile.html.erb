<% content_for :page_title, "Settings" %>

<div class="max-w-3xl">
  <div class="mb-6">
    <h1 class="font-[family-name:var(--font-display)] text-4xl tracking-tight">Settings</h1>
    <p class="mt-1 text-[var(--color-fg-muted)]">Manage your account and preferences.</p>
  </div>

  <%= render "tabs" %>

  <div class="card">
    <h2 class="font-[family-name:var(--font-display)] text-2xl tracking-tight mb-2">Profile</h2>
    <p class="text-sm text-[var(--color-fg-muted)] mb-6">Your name, email, and avatar.</p>

    <%= form_with model: current_user, url: profile_settings_path, method: :patch, html: { class: "space-y-6" } do |f| %>
      <% if current_user.errors.any? %>
        <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
          <p class="font-medium text-[var(--color-danger)] mb-2">Please fix the following:</p>
          <ul class="space-y-1 text-[var(--color-fg-muted)]">
            <% current_user.errors.full_messages.each do |msg| %>
              <li>• <%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex items-center gap-5">
        <div class="w-20 h-20 rounded-full bg-[var(--color-accent-700)] flex items-center justify-center text-2xl font-medium overflow-hidden">
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar.variant(resize_to_fill: [160, 160]), class: "w-full h-full object-cover" %>
          <% else %>
            <%= current_user.initials %>
          <% end %>
        </div>
        <div>
          <%= f.label :avatar, "Avatar", class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1" %>
          <%= f.file_field :avatar, accept: "image/*", class: "text-sm text-[var(--color-fg-muted)] file:mr-3 file:px-3 file:py-1.5 file:rounded-[var(--radius-sm)] file:border-0 file:bg-[var(--color-bg-overlay)] file:text-[var(--color-fg-primary)] file:cursor-pointer hover:file:bg-[var(--color-bg-hover)]" %>
          <p class="text-xs text-[var(--color-fg-faint)] mt-1">PNG, JPG up to 5MB.</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
          <%= f.text_field :name,
              class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
          <%= f.email_field :email,
              class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
        </div>
      </div>

      <div class="flex items-center justify-between pt-4 border-t border-[var(--color-border-subtle)]">
        <%= link_to "Change password", edit_user_registration_path, class: "text-sm text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
        <%= f.submit "Save changes",
            class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
