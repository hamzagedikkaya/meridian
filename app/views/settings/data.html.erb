<% content_for :page_title, "Settings" %>

<div class="max-w-3xl">
  <div class="mb-6">
    <h1 class="font-[family-name:var(--font-display)] text-4xl tracking-tight">Settings</h1>
    <p class="mt-1 text-[var(--color-fg-muted)]">Manage your account and preferences.</p>
  </div>

  <%= render "tabs" %>

  <div class="card">
    <h2 class="font-[family-name:var(--font-display)] text-2xl tracking-tight mb-2">Data</h2>
    <p class="text-sm text-[var(--color-fg-muted)] mb-6">Backup, restore, and export your Meridian data.</p>

    <div class="space-y-4">
      <div class="p-5 rounded-[var(--radius-md)] border border-[var(--color-border-default)] bg-[var(--color-bg-base)]">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-sm font-medium text-[var(--color-fg-primary)] mb-1">Backup & Restore</p>
            <p class="text-sm text-[var(--color-fg-muted)]">Move your data with a pg_dump + ActiveStorage tar.gz archive.</p>
            <% if @last_backup %>
              <p class="text-xs text-[var(--color-fg-faint)] mt-2">Last backup: <%= time_ago_in_words(@last_backup.created_at) %> ago · <%= @last_backup.display_size %></p>
            <% end %>
          </div>
          <%= link_to "Open Backups →", backups_path, class: "text-sm text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)] flex-shrink-0" %>
        </div>
      </div>

      <div class="p-5 rounded-[var(--radius-md)] border border-[var(--color-border-default)] bg-[var(--color-bg-base)]">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-sm font-medium text-[var(--color-fg-primary)] mb-1">CSV export</p>
            <p class="text-sm text-[var(--color-fg-muted)]">Export finance transactions as CSV.</p>
          </div>
          <%= link_to "Export CSV →", finance_transactions_export_path(format: :csv), class: "text-sm text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)] flex-shrink-0" %>
        </div>
      </div>

      <div class="p-5 rounded-[var(--radius-md)] border border-[var(--color-border-default)] bg-[var(--color-bg-base)]">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-sm font-medium text-[var(--color-fg-primary)] mb-1">iCal feed</p>
            <p class="text-sm text-[var(--color-fg-muted)]">Eventleri telefonun takvimine read-only feed olarak abone et.</p>
          </div>
          <%= link_to "Open feed →", calendar_feed_path, class: "text-sm text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)] flex-shrink-0" %>
        </div>
      </div>
    </div>
  </div>
</div>
