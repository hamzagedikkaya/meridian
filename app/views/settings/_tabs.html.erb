<%
  tabs = [
    { key: :profile,       label: "Profile",       path: profile_settings_path },
    { key: :preferences,   label: "Preferences",   path: preferences_settings_path },
    { key: :data,          label: "Data",          path: data_settings_path },
    { key: :notifications, label: "Notifications", path: notifications_settings_path }
  ]
%>

<div class="border-b border-[var(--color-border-subtle)] mb-8">
  <nav class="flex gap-1 -mb-px">
    <% tabs.each do |tab| %>
      <% is_active = action_name == tab[:key].to_s || action_name == "update_#{tab[:key]}" %>
      <%= link_to tab[:path],
          class: "px-4 py-3 text-sm font-medium border-b-2 transition-colors " +
                 (is_active ?
                   "border-[var(--color-accent-500)] text-[var(--color-fg-primary)]" :
                   "border-transparent text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)] hover:border-[var(--color-border-default)]") do %>
        <%= tab[:label] %>
      <% end %>
    <% end %>
  </nav>
</div>
