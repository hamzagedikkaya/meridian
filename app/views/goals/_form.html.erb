<%
  input_cls = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)]"
  label_cls = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
%>

<%= form_with model: goal, html: { class: "space-y-5" } do |f| %>
  <% if goal.errors.any? %>
    <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
      <ul class="space-y-1 text-[var(--color-fg-muted)]"><% goal.errors.full_messages.each { |m| %><li>• <%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: label_cls %>
    <%= f.text_field :name, autofocus: true, class: input_cls %>
  </div>

  <div>
    <%= f.label :description, class: label_cls %>
    <%= f.text_area :description, rows: 2, class: input_cls %>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <%= f.label :target_type, "Type", class: label_cls %>
      <%= f.select :target_type, Goal::TARGET_TYPES.map { |t| [ t.titleize, t ] }, {}, class: input_cls %>
    </div>
    <div>
      <%= f.label :status, class: label_cls %>
      <%= f.select :status, Goal::STATUSES.map { |s| [ s.titleize, s ] }, {}, class: input_cls %>
    </div>
    <div>
      <%= f.label :target_value, class: label_cls %>
      <%= f.number_field :target_value, step: 0.01, min: 0, class: input_cls %>
    </div>
    <div>
      <%= f.label :unit, class: label_cls %>
      <%= f.text_field :unit, placeholder: "TRY, kg, gün…", class: input_cls %>
    </div>
    <div>
      <%= f.label :current_value, class: label_cls %>
      <%= f.number_field :current_value, step: 0.01, min: 0, class: input_cls %>
    </div>
    <div>
      <%= f.label :deadline, class: label_cls %>
      <%= f.date_field :deadline, class: input_cls %>
    </div>
    <div>
      <%= f.label :color, class: label_cls %>
      <%= f.color_field :color, class: input_cls + " h-10" %>
    </div>
  </div>

  <div class="flex justify-between items-center pt-4 border-t border-[var(--color-border-subtle)]">
    <%= link_to "Cancel", goals_path, class: "text-sm text-[var(--color-fg-muted)]" %>
    <%= f.submit (goal.persisted? ? "Update" : "Create"), class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] cursor-pointer" %>
  </div>
<% end %>
