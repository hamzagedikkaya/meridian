<%
  input_cls = "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)]"
  label_cls = "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5"
  hint_cls  = "mt-1 text-xs text-[var(--color-fg-faint)]"

  current_related_value =
    case goal.related
    when Account then "Account-#{goal.related.id}"
    when Habit   then "Habit-#{goal.related.id}"
    else nil
    end
%>

<%= form_with model: goal, data: { turbo_frame: "_top" }, html: { class: "space-y-5", data: { controller: "goal-form", "goal-form-current-type-value": goal.target_type } } do |f| %>
  <% if goal.errors.any? %>
    <div class="px-4 py-3 rounded-[var(--radius-md)] border border-[var(--color-danger)] bg-[var(--color-bg-overlay)] text-sm">
      <ul class="space-y-1 text-[var(--color-fg-muted)]"><% goal.errors.full_messages.each { |m| %><li>• <%= m %></li><% } %></ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, t("common.name"), class: label_cls %>
    <%= f.text_field :name, autofocus: true, class: input_cls %>
  </div>

  <div>
    <%= f.label :description, t("common.description"), class: label_cls %>
    <%= f.text_area :description, rows: 2, class: input_cls %>
  </div>

  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <%= f.label :target_type, t("goals.target_type"), class: label_cls %>
      <%= f.select :target_type,
          Goal::TARGET_TYPES.map { |type| [ t("goals.types.#{type}", default: type.titleize), type ] },
          {},
          class: input_cls,
          data: { action: "change->goal-form#switch" } %>
      <p class="<%= hint_cls %>"><%= t("goals.types_hint") %></p>
    </div>
    <div>
      <%= f.label :status, t("common.status"), class: label_cls %>
      <%= f.select :status, Goal::STATUSES.map { |s| [ t("goals.statuses.#{s}", default: s.titleize), s ] }, {}, class: input_cls %>
    </div>

    <%# Linked source — visible for financial + habit %>
    <div class="md:col-span-2" data-goal-form-target="linkedSource">
      <label class="<%= label_cls %>" data-goal-form-target="linkedLabel"><%= t("goals.log.link_account") %></label>
      <select name="goal[related]" class="<%= input_cls %>" data-goal-form-target="linkedSelect">
        <option value="none"><%= t("common.optional") %>…</option>
        <optgroup label="<%= t("nav.finance") %>" data-goal-form-target="accountsGroup">
          <% (@linkable_accounts || []).each do |a| %>
            <option value="Account-<%= a.id %>" <%= "selected" if current_related_value == "Account-#{a.id}" %>>
              <%= a.name %> (<%= money_format(a.balance_cents, currency: a.currency) %>)
            </option>
          <% end %>
        </optgroup>
        <optgroup label="<%= t("nav.habits") %>" data-goal-form-target="habitsGroup">
          <% (@linkable_habits || []).each do |h| %>
            <option value="Habit-<%= h.id %>" <%= "selected" if current_related_value == "Habit-#{h.id}" %>>
              <%= h.name %>
            </option>
          <% end %>
        </optgroup>
      </select>
      <p class="<%= hint_cls %>" data-goal-form-target="linkedHint"></p>
    </div>

    <div>
      <%= f.label :target_value, t("goals.target_value"), class: label_cls %>
      <%= f.number_field :target_value, step: 0.01, min: 0, class: input_cls %>
    </div>
    <div>
      <%= f.label :unit, t("goals.unit"), class: label_cls %>
      <%= f.text_field :unit, placeholder: t("goals.unit_placeholder"), class: input_cls %>
    </div>
    <div data-goal-form-target="currentValueField">
      <%= f.label :current_value, t("goals.current_value"), class: label_cls %>
      <%= f.number_field :current_value, step: 0.01, min: 0, class: input_cls %>
      <p class="<%= hint_cls %>"><%= t("goals.current_value_hint") %></p>
    </div>
    <div>
      <%= f.label :deadline, t("goals.deadline"), class: label_cls %>
      <%= f.date_field :deadline, class: input_cls %>
    </div>
    <div>
      <%= f.label :color, t("common.color"), class: label_cls %>
      <%= f.color_field :color, class: input_cls + " h-10" %>
    </div>
  </div>

  <div class="flex justify-between items-center pt-4 border-t border-[var(--color-border-subtle)]">
    <a href="#" data-action="click->modal#close" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]"><%= t("common.cancel") %></a>
    <%= f.submit (goal.persisted? ? t("common.update") : t("common.create")), class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] cursor-pointer" %>
  </div>
<% end %>
