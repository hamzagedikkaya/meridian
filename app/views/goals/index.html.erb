<% content_for :page_title, t("goals.title") %>
<% content_for :nav_key, "goals" %>

<div class="space-y-6">
  <div class="flex items-end justify-between">
    <div>
      <h2 class="font-[family-name:var(--font-display)] text-4xl tracking-tight"><%= t("goals.title") %></h2>
      <p class="text-[var(--color-fg-muted)] mt-1"><%= t("goals.subtitle") %></p>
    </div>
    <%= link_to t("goals.new"), new_goal_path, data: { turbo_frame: "modal" }, class: "px-3 py-2 text-sm bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] rounded-[var(--radius-sm)] font-medium" %>
  </div>

  <% if @active_goals.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% @active_goals.each do |g| %>
        <%= link_to goal_path(g), class: "card hover:border-[var(--color-border-default)] block" do %>
          <div class="flex items-start justify-between gap-3 mb-3">
            <div class="min-w-0">
              <p class="text-xs text-[var(--color-fg-muted)] uppercase tracking-wider"><%= t("goals.types.#{g.target_type}", default: g.target_type.titleize) %></p>
              <p class="text-lg font-medium mt-1 truncate"><%= g.name %></p>
            </div>
            <% if g.deadline %>
              <p class="text-xs text-[var(--color-fg-muted)] flex-shrink-0"><%= g.days_remaining %>d</p>
            <% end %>
          </div>
          <%= render "progress_bar", goal: g %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card text-center py-12">
      <p class="text-[var(--color-fg-muted)] mb-3"><%= t("goals.none") %></p>
      <%= link_to t("goals.create_first"), new_goal_path, data: { turbo_frame: "modal" }, class: "text-[var(--color-accent-400)]" %>
    </div>
  <% end %>

  <% if @achieved_goals.any? %>
    <div class="card">
      <h3 class="font-[family-name:var(--font-display)] text-xl tracking-tight mb-4 text-[var(--color-success)]"><%= t("goals.achieved") %></h3>
      <ul class="space-y-2">
        <% @achieved_goals.each do |g| %>
          <li class="flex items-center justify-between text-sm">
            <%= link_to g.name, goal_path(g), class: "text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]" %>
            <span class="text-xs text-[var(--color-success)]"><%= g.target_value.to_f.round %> <%= g.unit %></span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
