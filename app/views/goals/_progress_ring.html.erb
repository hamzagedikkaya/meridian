<%# Animated SVG progress ring. Sweeps from 0 to current percent on mount via
    CSS keyframe (ring-sweep). circumference = 2 * π * 56 ≈ 351.86. %>
<%
  size       = local_assigns.fetch(:size, 200)
  stroke     = local_assigns.fetch(:stroke, 14)
  radius     = (size - stroke) / 2.0
  circ       = 2 * Math::PI * radius
  pct        = [ [ goal.progress_percent.to_f, 0 ].max, 100 ].min
  offset     = circ - (circ * pct / 100.0)
%>
<div class="inline-flex flex-col items-center gap-3">
  <div class="relative" style="width: <%= size %>px; height: <%= size %>px;">
    <svg width="<%= size %>" height="<%= size %>" viewBox="0 0 <%= size %> <%= size %>" class="-rotate-90">
      <circle cx="<%= size / 2 %>" cy="<%= size / 2 %>" r="<%= radius %>"
              fill="none"
              stroke="var(--color-bg-overlay)"
              stroke-width="<%= stroke %>"/>
      <circle cx="<%= size / 2 %>" cy="<%= size / 2 %>" r="<%= radius %>"
              fill="none"
              stroke="<%= goal.color.presence || 'var(--color-accent-500)' %>"
              stroke-width="<%= stroke %>"
              stroke-linecap="round"
              stroke-dasharray="<%= circ.round(2) %>"
              style="--ring-start: <%= circ.round(2) %>; --ring-end: <%= offset.round(2) %>; animation: ring-sweep 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;"
              filter="drop-shadow(0 0 6px <%= goal.color.presence || '#B8860B' %>40)"/>
    </svg>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
      <span class="font-[family-name:var(--font-display)] text-3xl tracking-tight"
            data-controller="stat-counter"
            data-stat-counter-end-value="<%= pct %>"
            data-stat-counter-format-value="integer"
            data-stat-counter-duration-value="1100"
            data-stat-counter-locale-value="<%= I18n.locale %>"><%= pct.round %></span>
      <span class="text-xs text-[var(--color-fg-muted)] uppercase tracking-wider mt-0.5">%</span>
    </div>
  </div>
  <div class="text-xs text-[var(--color-fg-muted)] text-center">
    <span class="text-[var(--color-fg-primary)] font-medium"><%= goal.current_value.to_f.round(2) %></span>
    <span class="opacity-60">/</span>
    <%= goal.target_value.to_f.round(2) %> <%= goal.unit %>
  </div>
</div>
