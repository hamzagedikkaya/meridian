<% content_for :title, "#{t("auth.sign_in")} · Meridian" %>

<div class="mb-8">
  <h1 class="font-[family-name:var(--font-display)] text-4xl tracking-tight"><%= t("auth.welcome_back") %></h1>
  <p class="mt-2 text-[var(--color-fg-muted)]"><%= t("auth.sign_in_subtitle") %></p>
</div>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
  <div>
    <%= f.label :email, class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.email_field :email,
        autofocus: true,
        autocomplete: "email",
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
  </div>

  <div>
    <div class="flex items-center justify-between mb-1.5">
      <%= f.label :password, class: "block text-sm font-medium text-[var(--color-fg-muted)]" %>
      <% if devise_mapping.recoverable? %>
        <%= link_to t("auth.forgot_link"), new_password_path(resource_name), class: "text-xs text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
      <% end %>
    </div>
    <%= f.password_field :password,
        autocomplete: "current-password",
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <label class="flex items-center gap-2 text-sm text-[var(--color-fg-muted)] cursor-pointer">
      <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-[var(--color-border-default)] bg-[var(--color-bg-elevated)] text-[var(--color-accent-500)] focus:ring-[var(--color-accent-500)]" %>
      <%= t("auth.remember_me") %>
    </label>
  <% end %>

  <%= f.submit t("auth.sign_in"),
      class: "w-full px-4 py-2.5 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] transition-colors cursor-pointer" %>
<% end %>

<% if devise_mapping.registerable? %>
  <p class="mt-6 text-center text-sm text-[var(--color-fg-muted)]">
    <%= t("auth.no_account") %>
    <%= link_to t("auth.create_one"), new_registration_path(resource_name), class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)] font-medium" %>
  </p>
<% end %>
