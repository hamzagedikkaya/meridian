<% content_for :page_title, t("settings.profile.title") %>

<div class="max-w-xl mx-auto py-8">
  <div class="card">
    <h2 class="font-[family-name:var(--font-display)] text-2xl tracking-tight mb-6"><%= t("settings.profile.title") %></h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
      </div>

      <div>
        <%= f.label :password, t("settings.profile.new_password"), class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
        <% if @minimum_password_length %>
          <p class="mt-1 text-xs text-[var(--color-fg-faint)]"><%= t("settings.profile.password_min", min: @minimum_password_length) %></p>
        <% end %>
      </div>

      <div>
        <%= f.label :password_confirmation, t("settings.profile.confirm_password"), class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
      </div>

      <div>
        <%= f.label :current_password, class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
        <%= f.password_field :current_password, autocomplete: "current-password",
            class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-base)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
      </div>

      <div class="flex items-center justify-between pt-4 border-t border-[var(--color-border-subtle)]">
        <%= link_to t("common.back"), :back, class: "text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)]" %>
        <%= f.submit t("common.save_changes"),
            class: "px-4 py-2 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
