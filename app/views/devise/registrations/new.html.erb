<% content_for :title, "#{t("auth.create_account")} · Meridian" %>

<div class="mb-8">
  <h1 class="font-[family-name:var(--font-display)] text-4xl tracking-tight"><%= t("auth.create_account") %></h1>
  <p class="mt-2 text-[var(--color-fg-muted)]"><%= t("auth.create_account_subtitle") %></p>
</div>

<%= render "devise/shared/error_messages", resource: resource %>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
  <div>
    <%= f.label :name, t("common.name"), class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.text_field :name,
        autofocus: true,
        autocomplete: "name",
        placeholder: t("auth.your_name"),
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.email_field :email,
        autocomplete: "email",
        placeholder: t("auth.email_placeholder"),
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.password_field :password,
        autocomplete: "new-password",
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
    <% if @minimum_password_length %>
      <p class="mt-1 text-xs text-[var(--color-fg-faint)]"><%= t("auth.password_min", count: @minimum_password_length) %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :password_confirmation, t("auth.confirm_password"), class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.password_field :password_confirmation,
        autocomplete: "new-password",
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
  </div>

  <%= f.submit t("auth.create_button"),
      class: "w-full px-4 py-2.5 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] transition-colors cursor-pointer" %>
<% end %>

<p class="mt-6 text-center text-sm text-[var(--color-fg-muted)]">
  <%= t("auth.already_account") %>
  <%= link_to t("auth.sign_in"), new_session_path(resource_name), class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)] font-medium" %>
</p>
