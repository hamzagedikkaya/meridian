<% content_for :title, "Create account · Meridian" %>

<div class="mb-8">
  <h1 class="font-[family-name:var(--font-display)] text-4xl tracking-tight">Create your account</h1>
  <p class="mt-2 text-[var(--color-fg-muted)]">Start organizing — local, private, yours.</p>
</div>

<%= render "devise/shared/error_messages", resource: resource %>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
  <div>
    <%= f.label :name, class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.text_field :name,
        autofocus: true,
        autocomplete: "name",
        placeholder: "Your name",
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.email_field :email,
        autocomplete: "email",
        placeholder: "you@example.com",
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.password_field :password,
        autocomplete: "new-password",
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
    <% if @minimum_password_length %>
      <p class="mt-1 text-xs text-[var(--color-fg-faint)]"><%= @minimum_password_length %> character minimum.</p>
    <% end %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.password_field :password_confirmation,
        autocomplete: "new-password",
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
  </div>

  <%= f.submit "Create account",
      class: "w-full px-4 py-2.5 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] transition-colors cursor-pointer" %>
<% end %>

<p class="mt-6 text-center text-sm text-[var(--color-fg-muted)]">
  Already have an account?
  <%= link_to "Sign in", new_session_path(resource_name), class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)] font-medium" %>
</p>
