<% content_for :title, "Set new password · Meridian" %>

<div class="mb-8">
  <h1 class="font-[family-name:var(--font-display)] text-4xl tracking-tight">Set a new password</h1>
  <p class="mt-2 text-[var(--color-fg-muted)]">Pick something strong.</p>
</div>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div>
    <%= f.label :password, "New password", class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.password_field :password,
        autofocus: true,
        autocomplete: "new-password",
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
    <% if @minimum_password_length %>
      <p class="mt-1 text-xs text-[var(--color-fg-faint)]"><%= @minimum_password_length %> character minimum.</p>
    <% end %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-[var(--color-fg-muted)] mb-1.5" %>
    <%= f.password_field :password_confirmation,
        autocomplete: "new-password",
        class: "w-full px-3.5 py-2.5 bg-[var(--color-bg-elevated)] border border-[var(--color-border-default)] rounded-[var(--radius-sm)] text-[var(--color-fg-primary)] placeholder-[var(--color-fg-faint)] focus:outline-none focus:border-[var(--color-accent-500)] transition-colors" %>
  </div>

  <%= f.submit "Update password",
      class: "w-full px-4 py-2.5 bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-600)] text-[var(--color-bg-base)] font-medium rounded-[var(--radius-sm)] transition-colors cursor-pointer" %>
<% end %>

<%= render "devise/shared/links" %>
