<div class="mt-6 text-center text-sm text-[var(--color-fg-muted)] space-y-2">
  <% if controller_name != 'sessions' %>
    <div>
      <%= link_to t("auth.sign_in_link_text"), new_session_path(resource_name), class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
    </div>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <div>
      <%= link_to t("auth.create_account_link"), new_registration_path(resource_name), class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
    </div>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <div>
      <%= link_to t("auth.forgot_password_link"), new_password_path(resource_name), class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
    </div>
  <% end %>
</div>
