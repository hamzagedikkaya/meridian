<div class="mt-6 text-center text-sm text-[var(--color-fg-muted)] space-y-2">
  <% if controller_name != 'sessions' %>
    <div>
      <%= link_to "Sign in", new_session_path(resource_name), class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
    </div>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <div>
      <%= link_to "Create an account", new_registration_path(resource_name), class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
    </div>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <div>
      <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-[var(--color-accent-400)] hover:text-[var(--color-accent-300)]" %>
    </div>
  <% end %>
</div>
