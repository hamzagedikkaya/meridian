<header class="h-16 px-6 flex items-center justify-between border-b border-[var(--color-border-subtle)] bg-[var(--color-bg-base)]/80 backdrop-blur sticky top-0 z-20">
  <%# Left: title + breadcrumbs %>
  <div class="flex items-center gap-3">
    <% if title.present? %>
      <h1 class="font-[family-name:var(--font-display)] text-xl text-[var(--color-fg-primary)] tracking-tight"><%= title %></h1>
    <% end %>
    <% if breadcrumbs.any? %>
      <nav class="flex items-center gap-2 text-sm text-[var(--color-fg-muted)]">
        <% breadcrumbs.each_with_index do |crumb, i| %>
          <% if i.positive? %>
            <span class="text-[var(--color-fg-faint)]">/</span>
          <% end %>
          <% if crumb[:path].present? %>
            <a href="<%= crumb[:path] %>" class="hover:text-[var(--color-fg-primary)] transition-colors"><%= crumb[:label] %></a>
          <% else %>
            <span><%= crumb[:label] %></span>
          <% end %>
        <% end %>
      </nav>
    <% end %>
  </div>

  <%# Right: search + theme + user menu %>
  <div class="flex items-center gap-3">
    <button
      type="button"
      class="hidden md:flex items-center gap-2 px-3 py-1.5 rounded-[var(--radius-sm)] border border-[var(--color-border-default)] text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)] hover:border-[var(--color-border-strong)] transition-colors"
      data-controller="global-search"
      data-action="click->global-search#open"
      data-global-search-placeholder-value="<%= t("global_search.placeholder") %>"
      data-global-search-hint-min-value="<%= t("global_search.hint_min") %>"
      data-global-search-no-results-value="<%= t("global_search.no_results") %>"
      data-global-search-type-to-search-value="<%= t("global_search.type_to_search") %>"
      aria-label="<%= t("common.search") %>"
    >
      <%= render Ui::Icon.new(name: "search", size: 14) %>
      <span><%= t("common.search") %></span>
      <kbd class="ml-2 px-1.5 py-0.5 text-xs bg-[var(--color-bg-overlay)] rounded text-[var(--color-fg-muted)]">⌘K</kbd>
    </button>

    <button
      type="button"
      class="w-9 h-9 flex items-center justify-center rounded-[var(--radius-sm)] text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)] hover:bg-[var(--color-bg-hover)] transition-colors"
      data-controller="theme"
      data-action="click->theme#toggle"
      aria-label="Toggle theme"
    >
      <%= render Ui::Icon.new(name: "moon", size: 18) %>
    </button>

    <% if user %>
      <div class="relative" data-controller="menu">
        <button
          type="button"
          class="flex items-center gap-2 pl-3 pr-1.5 py-1 border-l border-[var(--color-border-subtle)] hover:bg-[var(--color-bg-hover)] rounded-r-[var(--radius-sm)] transition-colors"
          data-action="click->menu#toggle click@window->menu#closeIfOutside"
          aria-label="User menu"
        >
          <div class="w-8 h-8 rounded-full bg-[var(--color-accent-700)] flex items-center justify-center text-[var(--color-fg-primary)] text-sm font-medium overflow-hidden">
            <% if user.avatar.attached? %>
              <%= image_tag user.avatar, class: "w-full h-full object-cover" %>
            <% else %>
              <%= user.initials %>
            <% end %>
          </div>
          <span class="hidden md:inline text-sm text-[var(--color-fg-muted)]"><%= user.display_name %></span>
        </button>

        <div
          data-menu-target="panel"
          class="hidden absolute right-0 mt-2 w-56 bg-[var(--color-bg-overlay)] border border-[var(--color-border-default)] rounded-[var(--radius-md)] shadow-xl py-1 z-30"
        >
          <div class="px-3 py-2 border-b border-[var(--color-border-subtle)]">
            <p class="text-sm font-medium text-[var(--color-fg-primary)]"><%= user.display_name %></p>
            <p class="text-xs text-[var(--color-fg-muted)] truncate"><%= user.email %></p>
          </div>
          <%= link_to t("nav.settings"), settings_path, class: "block px-3 py-2 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)] hover:bg-[var(--color-bg-hover)] transition-colors" %>
          <%= button_to t("nav.sign_out"), destroy_user_session_path, method: :delete,
              class: "w-full text-left block px-3 py-2 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)] hover:bg-[var(--color-bg-hover)] transition-colors cursor-pointer",
              form: { class: "block" } %>
        </div>
      </div>
    <% else %>
      <%= link_to t("nav.sign_in"), new_user_session_path, class: "text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)] transition-colors" %>
    <% end %>
  </div>
</header>
