<aside
  class="hidden md:flex md:flex-col bg-[var(--color-bg-elevated)] border-r border-[var(--color-border-subtle)] <%= collapsed ? 'w-16' : 'w-60' %> transition-all duration-200"
  data-controller="sidebar"
  data-sidebar-collapsed-value="<%= collapsed %>"
>
  <%# Brand %>
  <div class="px-5 py-6 border-b border-[var(--color-border-subtle)]">
    <a href="/" class="flex items-center gap-2">
      <span class="text-[var(--color-accent-500)] text-xl">◐</span>
      <% unless collapsed %>
        <span class="font-[family-name:var(--font-display)] text-xl tracking-tight text-[var(--color-fg-primary)]">Meridian</span>
      <% end %>
    </a>
  </div>

  <%# Nav %>
  <nav class="flex-1 px-3 py-4 space-y-1">
    <% NAV_ITEMS.each do |item| %>
      <a
        href="<%= item[:path] %>"
        class="flex items-center gap-3 px-3 py-2 rounded-[var(--radius-sm)] text-sm transition-colors <%= active?(item[:key]) ? 'bg-[var(--color-bg-overlay)] text-[var(--color-fg-primary)]' : 'text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)] hover:bg-[var(--color-bg-hover)]' %>"
        data-nav-key="<%= item[:key] %>"
      >
        <span class="w-5 h-5 flex items-center justify-center text-[var(--color-fg-muted)]">
          <%= render Ui::Icon.new(name: item[:icon], size: 18) %>
        </span>
        <% unless collapsed %>
          <span><%= item[:label] %></span>
        <% end %>
      </a>
    <% end %>
  </nav>

  <%# Footer %>
  <div class="px-3 py-4 border-t border-[var(--color-border-subtle)]">
    <button
      type="button"
      class="flex items-center gap-3 px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg-primary)] hover:bg-[var(--color-bg-hover)] w-full transition-colors"
      data-action="click->sidebar#toggle"
    >
      <span class="w-5 h-5 flex items-center justify-center">⇔</span>
      <% unless collapsed %>
        <span>Collapse</span>
      <% end %>
    </button>
  </div>
</aside>
